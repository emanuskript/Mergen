# Replace YOUR_VM_IP with the actual public IP or domain name.
# Using an IP -> Caddy serves plain HTTP on :80.
# Using a domain -> Caddy auto-provisions HTTPS via Let's Encrypt.

{$SITE_ADDRESS::80} {
	@backend path /api /api/* /docs /redoc /openapi.json

	handle @backend {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
